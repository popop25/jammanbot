# Slack bot token, starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack app-level token for Socket Mode, starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token

# Optional. Defaults to ./data/jammanbot.sqlite3
JAMMANBOT_DB_PATH=./data/jammanbot.sqlite3

# Optional. Defaults to codex.
JAMMANBOT_CODEX_COMMAND=codex

# Optional. Keep "-" so the prompt is read from stdin.
JAMMANBOT_CODEX_ARGS=exec - --json --ephemeral --skip-git-repo-check

# Optional. Increase for very long threads.
JAMMANBOT_CODEX_TIMEOUT_SECONDS=240

# Optional. Message limits used when building context.
JAMMANBOT_MAX_THREAD_MESSAGES=160
JAMMANBOT_MAX_CHANNEL_MESSAGES=80

# Optional. Number of background workers for Slack requests.
JAMMANBOT_WORKERS=2

# Optional. Comma-separated Slack channel IDs where automatic link summaries are enabled.
# Leave empty for mention-only behavior.
JAMMANBOT_AUTO_LINK_CHANNELS=

# Optional. Keep false for public-safe defaults. Set true only for trusted local/internal use.
JAMMANBOT_ALLOW_PRIVATE_LINK_HOSTS=false

# Optional. Maximum response bytes read for link summaries.
JAMMANBOT_LINK_FETCH_MAX_BYTES=2000000

# Optional. Cafeteria fetch tries verified HTTPS first and retries without verification
# only on certificate verification failures. Set false to skip verification from the start.
JAMMANBOT_CAFETERIA_VERIFY_SSL=true

# Optional. Let JammanBot answer short non-feature chatter with local Codex.
JAMMANBOT_ENABLE_CASUAL_CHAT=true
JAMMANBOT_CASUAL_CHAT_MAX_CHARS=500

# Optional. Comma-separated Slack channel IDs for automatic weekday lunch notifications.
# Leave empty to disable. Default time is 11:10 Asia/Seoul.
JAMMANBOT_LUNCH_NOTIFY_CHANNELS=
JAMMANBOT_LUNCH_NOTIFY_TIME=11:10
JAMMANBOT_LUNCH_NOTIFY_WEEKDAYS_ONLY=true
JAMMANBOT_LUNCH_NOTIFY_IMAGE_RETRIES=5
JAMMANBOT_LUNCH_NOTIFY_IMAGE_RETRY_SECONDS=60
