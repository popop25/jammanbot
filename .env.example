# Slack bot token, starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack app-level token for Socket Mode, starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token

# Optional. Defaults to ./data/jammanbot.sqlite3
JAMMANBOT_DB_PATH=./data/jammanbot.sqlite3

# Optional. Defaults to codex.
JAMMANBOT_CODEX_COMMAND=codex

# Optional. Keep "-" so the prompt is read from stdin.
JAMMANBOT_CODEX_ARGS=exec - --json --ephemeral --skip-git-repo-check

# Optional. Increase for very long threads.
JAMMANBOT_CODEX_TIMEOUT_SECONDS=240

# Optional. Message limits used when building context.
JAMMANBOT_MAX_THREAD_MESSAGES=160
JAMMANBOT_MAX_CHANNEL_MESSAGES=80

# Optional. Comma-separated Slack channel IDs where automatic link summaries are enabled.
# Leave empty for mention-only behavior.
JAMMANBOT_AUTO_LINK_CHANNELS=

